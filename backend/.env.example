# === SEGURANÇA ===
# Chave para rotas admin (/trigger-check, /search-now, /interpret)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=troque-por-uma-chave-segura

# URL pública do frontend (usada nos links de email)
APP_URL=http://localhost:3000

# === SERVIDOR ===
PORT=3001
NODE_ENV=development

# === BANCO DE DADOS ===
# SQLite para MVP (arquivo local, sem instalação)
DB_PATH=./data/radar.db

# === OPENAI (LLM para mensagens inteligentes) ===
OPENAI_API_KEY=sk-...sua-chave-aqui...

# === EMAIL (Resend.com - free tier: 100 emails/dia) ===
RESEND_API_KEY=re_...sua-chave-aqui...
EMAIL_FROM=alertas@seudominio.com

# === API DE VOOS ===
# Opção 1: Amadeus (free tier disponível)
AMADEUS_CLIENT_ID=...
AMADEUS_CLIENT_SECRET=...

# Opção 2: AviationStack (free tier: 500 req/mês)
AVIATIONSTACK_API_KEY=...

# Para MVP: USE_MOCK_API=true (sem precisar de API real)
USE_MOCK_API=true

# === SCHEDULER ===
# Intervalo de verificação (cron expression)
# A cada 6 horas: "0 */6 * * *"
# A cada hora: "0 * * * *"
# A cada 30min (dev): "*/30 * * * *"
CRON_SCHEDULE="0 */6 * * *"

# === ALERTAS ===
# Queda mínima (%) para disparar alerta
MIN_PRICE_DROP_PERCENT=15

# Janela de análise histórica (dias)
PRICE_HISTORY_DAYS=30

# === FRONTEND ===
FRONTEND_URL=http://localhost:3000
